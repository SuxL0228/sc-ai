{
    "name": "sc-ai",
    "description": "💥 SC 智答。一次提问，多款国产 AI（DeepSeek、豆包、通义千问、元宝、文心一言等）同屏对撞。零成本利用网页原生算力交叉验证，默认由 DeepSeek 担任智能评审一键归纳最优解，专治模型偏科与幻觉。",
    "license": "GPL-3.0-or-later",
    "private": true,
    "version": "1.2.1",
    "type": "module",
    "workspaces": [
        "packages/inject",
        "packages/site"
    ],
    "scripts": {
        "dev": "bun run build:inject && tsc --noEmit && vite build --watch",
        "dev:site": "cd packages/site && bun dev",
        "build:site": "cd packages/site && bun run build",
        "typecheck": "tsc --noEmit && (cd packages/inject && bun run typecheck)",
        "build:inject": "bun --filter @sc-ai/inject build",
        "build": "bun run build:inject && tsc --noEmit && vite build",
        "build:test": "bun run build:inject && tsc --noEmit && vite build && bun run test",
        "test": "playwright test",
        "test:ui": "playwright test --ui"
    },
    "dependencies": {
        "@ant-design/icons": "^6.2.5",
        "@ant-design/x": "^2.7.0",
        "@ant-design/x-markdown": "^2.7.0",
        "@ant-design/x-sdk": "^2.7.0",
        "@lobehub/icons": "^5.10.0",
        "antd": "^6.4.3",
        "antd-style": "^4.1.0",
        "dayjs": "^1.11.21",
        "motion": "^12.40.0",
        "openai": "^6.41.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-markdown": "^10.1.0",
        "zustand": "^5.0.14"
    },
    "sideEffects": false,
    "devDependencies": {
        "@crxjs/vite-plugin": "^2.4.0",
        "@playwright/test": "^1.60.0",
        "@types/chrome": "^0.1.42",
        "@types/node": "^24.12.4",
        "@types/react": "^19.2.16",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react-swc": "^4.3.1",
        "cross-env": "^10.1.0",
        "typescript": "~5.9.3",
        "vite": "^7.3.5",
        "vite-plugin-compression": "^0.5.1",
        "vite-plugin-zip-pack": "^1.2.4"
    }
}